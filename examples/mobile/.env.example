# React Native / Expo — copy to .env in your mobile project

# ── Backend ───────────────────────────────────────────────────────────────────
# iOS Simulator:    http://localhost:3000
# Android Emulator: http://10.0.2.2:3000
# Physical device:  http://192.168.x.x:3000  (run: ipconfig getifaddr en0)
EXPO_PUBLIC_API_URL=http://localhost:3000

# ── LinkedIn ──────────────────────────────────────────────────────────────────
# Client ID is public — safe here. Secret stays on the server.
EXPO_PUBLIC_LINKEDIN_CLIENT_ID=86kkj441zxqdkn
# Must be registered verbatim in LinkedIn Developer Console → Auth → Redirect URLs
EXPO_PUBLIC_LINKEDIN_REDIRECT_URI=tedxpune://auth/callback

# ── Google ────────────────────────────────────────────────────────────────────
# Use the WEB client ID here (not the iOS one) — this is what the backend verifies against
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# ── Apple ─────────────────────────────────────────────────────────────────────
# No env vars needed on the mobile side — the native SDK handles everything.
# Just enable "Sign In with Apple" capability in Xcode.
